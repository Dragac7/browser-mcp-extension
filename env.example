# WebSocket port the Chrome extension connects to (default: 9001)
WS_PORT=9001

# WebSocket bearer token (optional — if set, the extension must send it to connect)
# WS_TOKEN=

# HTTP API server port (default: 9082)
HTTP_PORT=9082

# Path to JS scripts directory (default: ./resources/js_scripts)
JS_SCRIPTS_PATH=./resources/js_scripts

# Directory for page snapshots (default: in-memory only, no disk writes)
# Set to persist snapshots to disk for debugging:
# OBSERVATIONS_DIR=./observations
