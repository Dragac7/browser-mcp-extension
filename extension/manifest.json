{
  "manifest_version": 3,
  "name": "WebSocket Browser Controller",
  "version": "1.1.0",
  "description": "Browser automation extension controlled via WebSocket",
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "alarms",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Automation Controller",
    "default_popup": "popup.html"
  }
}
